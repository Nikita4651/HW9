
services:
  mysqldb:
    image: mysql:latest
    ports:
      - '3306:3306'
    environment:
      - MYSQL_RANDOM_ROOT_PASSWORD=yes
      - MYSQL_DATABASE=app
      - MYSQL_USER=app
      - MYSQL_PASSWORD=pass
  postgresdb:
    image: postgres:latest
    ports:
      - '5432:5432'
    volumes:


      - ./init-scripts:/docker-entrypoint-initdb.d

      - db-data:/var/lib/mysql
    environment:
      - POSTGRES_DB=app
      - POSTGRES_USER=app
      - POSTGRES_PASSWORD=pass



  sut:
      image: openjdk:11-jre-slim
      depends_on:
        - db
      command: >
        java -jar /app/app-deadline.jar
        -P:jdbc.url=jdbc:mysql://db:3306/deadline_db
        -P:jdbc.user=appuser
        -P:jdbc.password=apppass
      volumes:
        - ./artifacts:/app
      ports:
        - "8080:8080"

volumes:
  db-data: